<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md_theme_surface"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/iv_back"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:background="@color/md_theme_surface"
        app:navigationIcon="@drawable/ic_arrow_back_24">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="对话"
            android:textSize="@dimen/text_size_title"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onSurface" />
    </com.google.android.material.appbar.MaterialToolbar>

    <LinearLayout
        android:id="@+id/layout_request_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingVertical="@dimen/spacing_md"
        android:background="@color/md_theme_surfaceVariant"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_request_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="当前仅为私聊"
            android:textSize="@dimen/text_size_body"
            android:textColor="@color/md_theme_onSurfaceVariant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_apply_join"
            style="@style/Widget.Partner.Button.Tonal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="申请加入"
            android:textSize="@dimen/text_size_caption" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/spacing_sm"
        android:clipToPadding="false" />

    <LinearLayout
        android:id="@+id/input_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="@color/md_theme_surface"
        android:elevation="4dp">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Partner.TextInputLayout.Filled"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="输入消息">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send"
            style="@style/Widget.Partner.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="发送"
            app:icon="@drawable/ic_send_24" />
    </LinearLayout>
</LinearLayout>