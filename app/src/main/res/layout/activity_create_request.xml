<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md_theme_surface"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/iv_back"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:background="@color/md_theme_surface"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:title="发布搭子需求"
        app:titleTextColor="@color/md_theme_onSurface" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/spacing_lg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Partner.TextInputLayout.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:hint="标题*">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Partner.TextInputLayout.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:hint="描述*">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:gravity="top"
                    android:inputType="textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="分类*"
                android:textSize="@dimen/text_size_body"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <com.androidcourse.partner_map.view.widget.CategoryPicker
                android:id="@+id/category_picker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Partner.TextInputLayout.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:hint="需求位置*"
                app:startIconDrawable="@drawable/ic_location_on_24">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/tv_request_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:text="点击选择位置" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="人数上限*"
                android:textSize="@dimen/text_size_body"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_md">

                <ImageView
                    android:id="@+id/iv_minus"
                    android:layout_width="@dimen/quantity_button_size"
                    android:layout_height="@dimen/quantity_button_size"
                    android:src="@drawable/ic_remove_24"
                    android:contentDescription="减少"
                    android:background="@drawable/bg_input_rounded"
                    android:padding="@dimen/spacing_sm"
                    android:tint="@color/md_theme_primary" />

                <TextView
                    android:id="@+id/tv_max_participants"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/spacing_sm"
                    android:text="1"
                    android:textSize="@dimen/text_size_subtitle"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="@color/md_theme_onSurface" />

                <ImageView
                    android:id="@+id/iv_plus"
                    android:layout_width="@dimen/quantity_button_size"
                    android:layout_height="@dimen/quantity_button_size"
                    android:src="@drawable/ic_add_24"
                    android:contentDescription="增加"
                    android:background="@drawable/bg_input_rounded"
                    android:padding="@dimen/spacing_sm"
                    android:tint="@color/md_theme_primary" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Partner.TextInputLayout.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:hint="预定时间*"
                app:startIconDrawable="@drawable/ic_schedule_24">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/tv_scheduled_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:text="点击选择日期和时间" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Partner.TextInputLayout.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:hint="失效提前量*"
                app:startIconDrawable="@drawable/ic_schedule_24">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/tv_expire_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:text="1小时" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="性别要求"
                android:textSize="@dimen/text_size_body"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <RadioGroup
                android:id="@+id/rg_gender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_md">
                <RadioButton
                    android:id="@+id/rb_any"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="不限"
                    android:checked="true"
                    android:layout_marginEnd="@dimen/spacing_md" />
                <RadioButton
                    android:id="@+id/rb_male_only"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="仅男"
                    android:layout_marginEnd="@dimen/spacing_md" />
                <RadioButton
                    android:id="@+id/rb_female_only"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="仅女" />
            </RadioGroup>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Partner.TextInputLayout.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xl"
                android:hint="消费说明"
                app:expandedHintEnabled="false"
                app:placeholderText="费用分摊或预估消费"
                app:startIconDrawable="@drawable/ic_payments_24">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_cost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_publish"
                style="@style/Widget.Partner.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="发 布" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
