<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md_theme_surface"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/iv_back"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:background="@color/md_theme_surface"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:title="需求详情"
        app:titleTextColor="@color/md_theme_onSurface" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/spacing_lg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Partner.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:id="@+id/tv_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="分类"
                        android:textColor="@color/md_theme_primary"
                        android:textSize="@dimen/text_size_caption"
                        android:layout_marginBottom="@dimen/spacing_xs" />

                    <TextView
                        android:id="@+id/tv_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="标题"
                        android:textSize="@dimen/text_size_headline"
                        android:textStyle="bold"
                        android:textColor="@color/md_theme_onSurface"
                        android:layout_marginBottom="@dimen/spacing_md" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Partner.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:id="@+id/tv_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="地点"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/md_theme_onSurface"
                        android:drawableStart="@drawable/ic_location_on_24"
                        android:drawablePadding="@dimen/spacing_sm"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="状态"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/md_theme_onSurface"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <TextView
                        android:id="@+id/tv_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="时间"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/md_theme_onSurface"
                        android:drawableStart="@drawable/ic_schedule_24"
                        android:drawablePadding="@dimen/spacing_sm"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <TextView
                        android:id="@+id/tv_people"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="人数"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/md_theme_onSurface"
                        android:drawableStart="@drawable/ic_people_24"
                        android:drawablePadding="@dimen/spacing_sm"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <TextView
                        android:id="@+id/tv_gender"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="性别"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/md_theme_onSurface"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <TextView
                        android:id="@+id/tv_cost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="费用"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/md_theme_onSurface"
                        android:drawableStart="@drawable/ic_payments_24"
                        android:drawablePadding="@dimen/spacing_sm" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Partner.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="需求描述"
                        android:textStyle="bold"
                        android:textSize="@dimen/text_size_subtitle"
                        android:textColor="@color/md_theme_onSurface"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <TextView
                        android:id="@+id/tv_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="描述内容"
                        android:textSize="@dimen/text_size_body"
                        android:textColor="@color/md_theme_onSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Partner.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="参与者"
                        android:textStyle="bold"
                        android:textSize="@dimen/text_size_subtitle"
                        android:textColor="@color/md_theme_onSurface"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_participants"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tv_pending_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="待审批"
                android:textStyle="bold"
                android:textSize="@dimen/text_size_subtitle"
                android:textColor="@color/md_theme_onSurface"
                android:visibility="gone"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_pending_participations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <LinearLayout
                android:id="@+id/layout_publisher_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_md"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_edit"
                    style="@style/Widget.Partner.Button.Tonal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="编辑" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_delete"
                    style="@style/Widget.Partner.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:text="取消需求"
                    android:textColor="@color/md_theme_error" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_action"
                style="@style/Widget.Partner.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="进入私聊" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_secondary_action"
                style="@style/Widget.Partner.Button.Tonal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="申请加入"
                android:layout_marginTop="@dimen/spacing_sm"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>