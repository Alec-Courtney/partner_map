<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="分类"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/btn_cat_all"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="全部"
                android:textSize="12sp"
                android:background="#E0E0E0"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/btn_cat_study"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="学习"
                android:textSize="12sp"
                android:background="#E0E0E0"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/btn_cat_sport"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="运动"
                android:textSize="12sp"
                android:background="#E0E0E0"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/btn_cat_food"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="美食"
                android:textSize="12sp"
                android:background="#E0E0E0" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">
            <TextView
                android:id="@+id/btn_cat_travel"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="出行"
                android:textSize="12sp"
                android:background="#E0E0E0"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/btn_cat_fun"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="娱乐"
                android:textSize="12sp"
                android:background="#E0E0E0"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/btn_cat_shopping"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="购物"
                android:textSize="12sp"
                android:background="#E0E0E0"
                android:layout_marginEnd="4dp" />
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="学校"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/btn_school_all"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="全部学校"
                android:textSize="12sp"
                android:background="#E0E0E0"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/btn_school_mine"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="仅本校"
                android:textSize="12sp"
                android:background="#E0E0E0" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="距离"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/btn_dist_5"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="5km"
                android:textSize="12sp"
                android:background="#E0E0E0"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/btn_dist_10"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="10km"
                android:textSize="12sp"
                android:background="#E0E0E0"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/btn_dist_20"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="20km"
                android:textSize="12sp"
                android:background="#E0E0E0"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/btn_dist_all"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="不限"
                android:textSize="12sp"
                android:background="#E0E0E0" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="时间"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/btn_time_today"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="今天"
                android:textSize="12sp"
                android:background="#E0E0E0"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/btn_time_week"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="本周"
                android:textSize="12sp"
                android:background="#E0E0E0"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/btn_time_month"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="本月"
                android:textSize="12sp"
                android:background="#E0E0E0"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/btn_time_all"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="不限"
                android:textSize="12sp"
                android:background="#E0E0E0" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">
            <Button
                android:id="@+id/btn_reset"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="重置" />
            <Button
                android:id="@+id/btn_confirm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="确认"
                android:layout_marginStart="16dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
