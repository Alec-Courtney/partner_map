<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Partner.CardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_sm"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <TextView
            android:id="@+id/tv_target"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="评价对象"
            android:textSize="@dimen/text_size_subtitle"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onSurface"
            android:layout_marginBottom="@dimen/spacing_md" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="是否赴约？"
            android:textSize="@dimen/text_size_body"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <RadioGroup
            android:id="@+id/rg_attend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_md">
            <RadioButton
                android:id="@+id/rb_attend_yes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="是"
                android:checked="true"
                android:layout_marginEnd="@dimen/spacing_md" />
            <RadioButton
                android:id="@+id/rb_attend_no"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="否" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="评价？"
            android:textSize="@dimen/text_size_body"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <RadioGroup
            android:id="@+id/rg_praise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_lg">
            <RadioButton
                android:id="@+id/rb_praise_good"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="好评"
                android:checked="true"
                android:layout_marginEnd="@dimen/spacing_md" />
            <RadioButton
                android:id="@+id/rb_praise_bad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="差评" />
        </RadioGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit"
            style="@style/Widget.Partner.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="提 交" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>